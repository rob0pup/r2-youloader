{
  "name": "youloader",
  "version": "0.1.1",
  "private": true,
  "description": "Youloader — a desktop YouTube downloader. Paste a link, pick a quality, save the video or audio.",
  "homepage": "https://youloader.robinrahman.pro",
  "license": "MIT",
  "author": {
    "name": "Robin Rahman",
    "url": "https://robinrahman.pro"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rob0pup/r2-youloader.git"
  },
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "check-types": "tsc --noEmit",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@sentry/electron": "^7.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.2.0",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.10.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwindcss": "^4.2.4",
    "typescript": "5.8.3",
    "vite": "^6.0.7"
  },
  "resolutions": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-builder",
      "ffmpeg-static"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
